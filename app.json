{
  "expo": {
    "name": "Purefect Water Station",
    "slug": "water-station-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F6E56"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.purefect.waterstation",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F6E56"
      },
      "package": "com.purefect.waterstation"
    },
    "plugins": [
      "expo-notifications",
      "expo-updates"
    ],
    "extra": {
      "eas": {
        "projectId": "d471ce02-09f9-4ada-97b6-3f319c427c46"
      }
    },
    "owner": "eomtaehyun",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d471ce02-09f9-4ada-97b6-3f319c427c46"
    }
  }
}
